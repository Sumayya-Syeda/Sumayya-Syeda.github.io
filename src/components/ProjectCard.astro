---
import { categoryColors, type Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const colors = categoryColors[project.category];
---

<a
  href={`/projects/${project.slug}`}
  class="group rounded-xl border-l-4 border-y border-r border-paper-line p-6 hover:shadow-md hover:-translate-y-0.5 transition-all reveal h-full flex flex-col no-underline text-ink"
  style={`border-left-color: ${colors.strong}; background: linear-gradient(135deg, ${colors.pastel}55 0%, transparent 55%);`}
>
  <div class="flex items-baseline justify-between gap-3 mb-3">
    <span
      class="font-mono text-[10px] uppercase tracking-widest px-2 py-0.5 rounded"
      style={`background: ${colors.pastel}; color: ${colors.strong};`}
    >
      {project.category}
    </span>
    <p class="font-mono text-[11px] text-ink-faint whitespace-nowrap">{project.period}</p>
  </div>

  <h3 class="font-serif text-xl text-ink mb-1 leading-snug group-hover:text-accent transition-colors">
    {project.title}
  </h3>
  <p class="text-xs text-ink-muted mb-4">{project.context}</p>

  <p class="text-sm text-ink/90 leading-relaxed mb-4">{project.summary}</p>

  <ul class="mt-auto flex flex-wrap gap-1.5 mb-3">
    {project.tags.slice(0, 4).map((tag) => (
      <li
        class="font-mono text-[10px] uppercase tracking-wider text-ink-muted bg-paper-warm px-2 py-0.5 rounded"
      >
        {tag}
      </li>
    ))}
  </ul>

  <span
    class="font-mono text-[11px] uppercase tracking-widest inline-flex items-center gap-1 transition-transform group-hover:translate-x-0.5"
    style={`color: ${colors.strong};`}
  >
    Read more <span aria-hidden="true">→</span>
  </span>
</a>
