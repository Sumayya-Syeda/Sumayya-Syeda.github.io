---
import { withBase } from '../lib/path';

const { pathname } = Astro.url;
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/experience', label: 'Experience' },
  { href: '/contact', label: 'Contact' },
];

// Strip the base path off pathname so the comparison works against the
// unprefixed link hrefs above. Astro.url.pathname includes the base.
const baseNoSlash = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = pathname.startsWith(baseNoSlash)
  ? pathname.slice(baseNoSlash.length) || '/'
  : pathname;

const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="sticky top-0 z-40 backdrop-blur bg-paper/80 border-b border-paper-line">
  <nav class="max-w-page mx-auto px-6 h-14 flex items-center justify-between">
    <a href={withBase('/')} class="font-serif text-lg no-underline tracking-tight">
      Sumayya Syeda
    </a>
    <ul class="flex items-center gap-6 text-sm">
      {links.map((link) => (
        <li>
          <a
            href={withBase(link.href)}
            class={`no-underline transition-colors relative ${
              isActive(link.href)
                ? 'text-accent font-medium'
                : 'text-ink-muted hover:text-ink'
            }`}
          >
            {link.label}
            {isActive(link.href) && (
              <span
                class="absolute -bottom-1 left-0 right-0 h-0.5 rounded-full bg-accent"
                aria-hidden="true"
              ></span>
            )}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
