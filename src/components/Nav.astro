---
const { pathname } = Astro.url;
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/experience', label: 'Experience' },
  { href: '/contact', label: 'Contact' },
];

const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="sticky top-0 z-40 backdrop-blur bg-paper/80 border-b border-paper-line">
  <nav class="max-w-page mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="font-serif text-lg no-underline tracking-tight">
      Sumayya Syeda
    </a>
    <ul class="flex items-center gap-6 text-sm">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class={`no-underline transition-colors relative ${
              isActive(link.href)
                ? 'text-accent font-medium'
                : 'text-ink-muted hover:text-ink'
            }`}
          >
            {link.label}
            {isActive(link.href) && (
              <span
                class="absolute -bottom-1 left-0 right-0 h-0.5 rounded-full bg-accent"
                aria-hidden="true"
              ></span>
            )}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
