---
import type { IconName } from '../data/roadmap';

interface Props {
  name: IconName;
  size?: number;
  class?: string;
  strokeWidth?: number;
}

const { name, size = 24, class: className = '', strokeWidth = 1.6 } = Astro.props;

const common = {
  width: size,
  height: size,
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': strokeWidth,
  'stroke-linecap': 'round',
  'stroke-linejoin': 'round',
  class: className,
};
---

{name === 'rocket' && (
  <svg {...common}>
    <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" />
    <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />
    <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" />
    <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" />
  </svg>
)}

{name === 'plane' && (
  <svg {...common}>
    <path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z" />
  </svg>
)}

{name === 'flask' && (
  <svg {...common}>
    <path d="M10 2v7.31" />
    <path d="M14 9.3V1.99" />
    <path d="M8.5 2h7" />
    <path d="M14 9.3a6.5 6.5 0 1 1-4 0" />
    <path d="M5.5 17h13" />
  </svg>
)}

{name === 'database' && (
  <svg {...common}>
    <ellipse cx="12" cy="5" rx="9" ry="3" />
    <path d="M3 5v14a9 3 0 0 0 18 0V5" />
    <path d="M3 12a9 3 0 0 0 18 0" />
  </svg>
)}

{name === 'play' && (
  <svg {...common}>
    <circle cx="12" cy="12" r="10" />
    <polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke-linejoin="round" />
  </svg>
)}

{name === 'school' && (
  <svg {...common}>
    <path d="m22 9-10-5L2 9l10 5 10-5-10-5z" />
    <path d="M22 10v6" />
    <path d="M6 12.5V16c0 1.5 2.5 3 6 3s6-1.5 6-3v-3.5" />
  </svg>
)}

{name === 'scotty' && (
  <svg {...common}>
    {/* Stylized Scottish Terrier silhouette */}
    <path d="M3 16.5h18v2.5a1 1 0 0 1-1 1h-1.5l-.5 1h-1l-.5-1H8.5l-.5 1H7l-.5-1H4a1 1 0 0 1-1-1z" fill="currentColor" stroke="none" />
    <path d="M3 16.5V13a4 4 0 0 1 4-4h2.5c.3-1.4 1.4-2.5 2.5-2.5 1 0 1.5.7 1.5 1.5" fill="currentColor" stroke="none" />
    <path d="M5 9c0-1.5 1-2 2-2 .3-1 1.2-1.5 1.8-1" fill="none" />
    <circle cx="6.5" cy="12" r="0.6" fill="currentColor" stroke="none" />
  </svg>
)}

{name === 'spark' && (
  <svg {...common}>
    {/* Walmart-style spark — 6 rays around a small center */}
    <circle cx="12" cy="12" r="1.4" fill="currentColor" stroke="none" />
    <line x1="12" y1="2.5" x2="12" y2="7.5" />
    <line x1="12" y1="16.5" x2="12" y2="21.5" />
    <line x1="20.4" y1="7.2" x2="16.1" y2="9.7" />
    <line x1="7.9" y1="14.3" x2="3.6" y2="16.8" />
    <line x1="20.4" y1="16.8" x2="16.1" y2="14.3" />
    <line x1="7.9" y1="9.7" x2="3.6" y2="7.2" />
  </svg>
)}

{name === 'apple-logo' && (
  <svg {...common} stroke="none" fill="currentColor">
    {/* Stylized apple silhouette with bite and leaf */}
    <path d="M17.6 13.5c0-2.4 1.9-3.5 2-3.6-1.1-1.6-2.8-1.8-3.4-1.8-1.4-.1-2.8.9-3.5.9s-1.8-.8-3-.8c-1.6 0-3 .9-3.8 2.3-1.6 2.8-.4 7 1.2 9.3.8 1.1 1.7 2.4 2.9 2.3 1.2 0 1.6-.7 3-.7s1.8.7 3 .7c1.3 0 2-1.1 2.8-2.2.9-1.3 1.2-2.5 1.3-2.6-.1 0-2.5-.9-2.5-3.8z" />
