  <div class="max-w-page mx-auto px-6 py-8 flex flex-col sm:flex-row gap-3 justify-between text-sm text-ink-muted">
    <p>© {year} Sumayya Syeda</p>
    <ul class="flex gap-6">
      <li><a href="https://github.com/Sumayya-Syeda" class="no-underline hover:text-ink transition-colors">GitHub</a></li>
      <li><a href="https://linkedin.com/in/sums" class="no-underline hover:text-ink transition-colors">LinkedIn</a></li>
      <li><a href={withBase('/contact')} class="no-underline hover:text-ink transition-colors">Contact</a></li>
    </ul>
  </div>
</footer>
